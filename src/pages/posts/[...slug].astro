---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const desc = post.data.description.trim();
const chunks = desc
  .replace(/\s+/g, ' ')
  .split(/(?<=다\.|요\.|니다\.|까요\?|까요\.|세요\.|습니다\.)\s+/)
  .map((s) => s.trim())
  .filter(Boolean);
const bullets = (chunks.length >= 2 ? chunks.slice(0, 3) : [desc]).map((line) =>
  line.length > 40 ? `${line.slice(0, 40)}…` : line,
);
const shareBody = `[${post.data.title}]\n${bullets.map((b) => `- ${b}`).join('\n')}`;
const sharePayload = JSON.stringify({ body: shareBody });
---

<BaseLayout title={post.data.title} description={post.data.description} path="/posts/">
  <article class="detail-hero">
    <div class="container">
      <div class="post-row__meta">
        <span class="chip chip--teal">{post.data.category}</span>
        <span class="chip">업데이트 {post.data.updatedAt}</span>
      </div>
      <h1>{post.data.title}</h1>
      <div class="post-lead">
        <p class="hero__lead post-lead__text">{post.data.description}</p>
        <button type="button" class="share-btn" id="share-btn" aria-label="공유하기">공유</button>
      </div>
      <div class="prose" style="margin-top: 1.75rem;">
        <Content />
      </div>
      <p class="notice">
        본 글은 검토용 초안입니다. 실제 지급액·대상·일정은 정부·지자체 공식 공고를 기준으로 확인하세요.
      </p>
    </div>
  </article>

  <script id="share-payload" type="application/json" set:html={sharePayload} />
  <script is:inline>
    (function () {
      var btn = document.getElementById('share-btn');
      var payloadEl = document.getElementById('share-payload');
      if (!btn || !payloadEl) return;

      var payload = { body: '' };
      try {
        payload = JSON.parse(payloadEl.textContent || '{}');
      } catch (e) {}

      function buildMessage() {
        return String(payload.body || document.title) + '\n\n' + window.location.href;
      }

      function flashCopied() {
        btn.classList.add('is-copied');
        btn.textContent = '복사됨';
        setTimeout(function () {
          btn.classList.remove('is-copied');
          btn.textContent = '공유';
        }, 1600);
      }

      btn.addEventListener('click', async function () {
        var message = buildMessage();
        try {
          if (navigator.share) {
            await navigator.share({ text: message });
            return;
          }
        } catch (e) {
          if (e && e.name === 'AbortError') return;
        }
        try {
          await navigator.clipboard.writeText(message);
          flashCopied();
        } catch (e2) {
          window.prompt('아래 내용을 복사하세요', message);
        }
      });
    })();
  </script>
</BaseLayout>
