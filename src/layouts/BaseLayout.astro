---
import globalCss from '../styles/global.css?inline';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = '민생회복지원금',
  description = '2026 민생회복 소비쿠폰·지원금 신청 안내 (비공식)',
  path = Astro.url.pathname,
} = Astro.props;

const fullTitle =
  title === '민생회복지원금'
    ? '민생회복지원금 — 민생회복 소비쿠폰 안내'
    : `${title} | 민생회복지원금`;
const year = new Date().getFullYear();
const nav = [
  { href: '/posts/', label: '블로그' },
  { href: '/news/', label: '지원금 뉴스' },
  { href: '/guides/checklist/', label: '체크리스트' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="naver-site-verification" content="c078f9ec83600f153e6e80fd22fc84855dba86fe" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#e8f5f3" />
    <link rel="icon" href="/favicon.v2.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.v2.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16.v2.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.v2.png" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="민생쿠폰 블로그" href="/rss.xml" />
    <title>{fullTitle}</title>
    <style is:inline set:html={globalCss} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href="/">
          <picture>
            <source srcset="/brand-logo.webp" type="image/webp" />
            <img
              class="brand__logo"
              src="/brand-logo.png"
              alt=""
              width="36"
              height="36"
              decoding="async"
            />
          </picture>
          <span class="brand__text">
            <span class="brand__name">민생회복지원금</span>
            <span class="brand__tag">민생회복 소비쿠폰 안내</span>
          </span>
        </a>
        <nav class="nav" aria-label="주요">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={
                  path === item.href || (item.href !== '/' && path.startsWith(item.href))
                    ? 'page'
                    : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <button
          class="menu-btn"
          type="button"
          id="menu-btn"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="메뉴 열기"
        >
          <span class="menu-btn__bars" aria-hidden="true"></span>
        </button>
      </div>
      <div class="mobile-nav" id="mobile-nav" hidden>
        <div class="container mobile-nav__inner">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={
                  path === item.href || (item.href !== '/' && path.startsWith(item.href))
                    ? 'page'
                    : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-copy">© {year} 민생회복 소비쿠폰.kr</p>
        <p class="footer-note">
          민생쿠폰은 정부·지자체와 제휴·공식 관계가 없는 개인 안내용 사이트입니다. 지원 자격·금액·일정은
          정부24·지자체 공고 등 원문에서 확인해 주세요.
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById('menu-btn');
        var panel = document.getElementById('mobile-nav');
        if (!btn || !panel) return;
        function setOpen(open) {
          panel.hidden = !open;
          btn.setAttribute('aria-expanded', String(open));
          btn.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
          btn.classList.toggle('is-open', open);
        }
        btn.addEventListener('click', function () {
          setOpen(panel.hidden);
        });
        panel.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            setOpen(false);
          });
        });
      })();
    </script>
  </body>
</html>
